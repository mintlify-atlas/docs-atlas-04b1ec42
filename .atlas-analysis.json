  "keyFeatures": [
    "Parse ADF 1.0 XML into fully-typed TypeScript objects",
    "Validate documents against the ADF 1.0 spec with errors and warnings",
    "Fluent builder API (ADFProspectBuilder, ADFBuilder) for constructing leads without reading the spec",
    "Serialize typed ADFDocument objects back to ADF-compliant XML",
    "One-shot factory functions (generateProspect, generateADF) for simple use cases",
    "Zero runtime dependencies in the distributed bundle",
    "Full TypeScript types for all ADF entities, enums, and input shapes"
  ],
  "publicApiSurface": [
    "ADFparse(xmlString: string): ADFDocument",
    "ADFvalidate(doc: ADFDocument): ValidationResult",
    "ADFserialize(doc: ADFDocument): string",
    "ADFProspectBuilder — fluent builder for a single lead",
    "ADFBuilder — fluent builder for a multi-prospect document",
    "generateProspect(input: ProspectInput): string",
    "generateADF(input: ADFInput): string",
    "buildProspect(input: ProspectInput): ADFProspect",
    "buildDocument(input: ADFInput): ADFDocument",
    "ADFParseError",
    "ADFValidationError",
    "ADFDocument, ADFProspect, ADFVehicle, ADFCustomer, ADFVendor, ADFProvider",
    "ADFContact, ADFId, ADFName, ADFEmail, ADFPhone, ADFAddress",
    "ADFPrice, ADFOdometer, ADFFinance, ADFAmount, ADFBalance, ADFOption",
    "ADFTimeFrame, ADFColorCombination",
    "ProspectInput, VehicleInput, CustomerInput, VendorInput, ProviderInput",
    "ValidationIssue, ValidationResult, IssueSeverity"
  ]
}
