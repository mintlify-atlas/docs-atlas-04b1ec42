  "projectType": "sdk-library",
  "projectName": "adf-kit",
  "projectDescription": "A TypeScript library for parsing, validating, generating, and serializing Auto-lead Data Format (ADF) 1.0 XML documents used in automotive CRMs and lead aggregators.",
